import { TaskCardUi, Layout, PriorityColors } from "../common.slint";
import { Theme } from "../theme.slint";

// ---- Draggable task card (3-row layout) ----

export component Card inherits Rectangle {
    in property <TaskCardUi> task;
    in-out property <int> source-column;
    in-out property <int> source-index;
    pure callback make-data(string, int, int) -> data-transfer;

    height: Layout.card-height;
    background: Theme.card-bg;
    border-radius: 6px;
    border-width: 1px;
    border-color: Theme.card-border;
    drop-shadow-blur: 6px;
    drop-shadow-offset-y: 2px;
    drop-shadow-color: Theme.shadow;

    DragArea {
        allow-move: true;
        data: root.make-data(root.task.id, root.source-column, root.source-index);
        opacity: self.dragging ? 0.4 : 1.0;

        VerticalLayout {
            padding: 8px;
            spacing: 5px;
            alignment: start;

            // ---- Row 1: Title ----
            Text {
                text: root.task.title;
                font-weight: 600;
                color: Theme.text-primary;
                overflow: elide;
            }

            // ---- Row 2: Priority + Due date ----
            HorizontalLayout {
                spacing: 6px;

                // Priority dot + label
                HorizontalLayout {
                    spacing: 4px;

                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: root.task.priority == 0 ? PriorityColors.p0 :
                                    root.task.priority == 1 ? PriorityColors.p1 :
                                    root.task.priority == 2 ? PriorityColors.p2 :
                                    PriorityColors.p3;
                    }

                    Text {
                        text: "P" + root.task.priority;
                        font-size: 12px;
                        color: root.task.is-overdue ? Theme.overdue : Theme.text-secondary;
                    }
                }

                if root.task.due-text != "": Text {
                    text: root.task.due-text;
                    font-size: 12px;
                    color: root.task.is-overdue ? Theme.overdue : Theme.text-secondary;
                    font-weight: root.task.is-overdue ? 600 : 400;
                }
            }

            // ---- Row 3: Tags ----
            if root.task.tags.length > 0: HorizontalLayout {
                spacing: 4px;
                alignment: start;

                for tag in root.task.tags: Rectangle {
                    min-width: 20px;
                    height: 20px;
                    border-radius: 3px;
                    background: Theme.text-secondary.with-alpha(0.15);

                    HorizontalLayout {
                        padding-left: 6px;
                        padding-right: 6px;

                        Text {
                            text: tag;
                            font-size: 10px;
                            color: Theme.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
