import { ComboBox, CheckBox } from "std-widgets.slint";
import { ThemeSettings } from "../common.slint";
import { Theme } from "../theme.slint";
import { StyledTextInput } from "../widgets/styled-text-input.slint";
import { DialogCard, DialogHeader } from "../widgets/dialog-shell.slint";
import { DialogFooter } from "../widgets/dialog-footer.slint";

component SortColumnRow {
    in-out property <int> sort-field;
    in-out property <bool> ascending;
    in property <string> label;

    HorizontalLayout {
        spacing: 8px;
        alignment: center;
        Text {
            text: root.label;
            color: Theme.text-primary;
            vertical-alignment: center;
            min-width: 80px;
        }
        ComboBox {
            model: ["手动", "优先级", "截止日期", "标题"];
            current-index <=> root.sort-field;
        }
        CheckBox {
            checked <=> root.ascending;
        }
        Text {
            text: "升序";
            font-size: 13px;
            vertical-alignment: center;
            color: Theme.text-secondary;
        }
    }
}

export component SettingsDialog inherits Rectangle {
    callback cancel();
    callback confirm();

    x: 0; y: 0; width: 100%; height: 100%;
    background: #00000044;
    TouchArea { }

    property <int> theme-index: ThemeSettings.theme-mode == "light" ? 1
        : ThemeSettings.theme-mode == "dark" ? 2 : 0;
    in-out property <string> days-text: ThemeSettings.auto-archive-days;

    // Close behavior: "" (unset / ask every time), "quit", "minimize_to_tray"
    property <int> close-behavior-index: ThemeSettings.close-behavior == "quit" ? 1
        : ThemeSettings.close-behavior == "minimize_to_tray" ? 2 : 0;

    // Sort combo indices — initialized from ThemeSettings, written back on confirm.
    property <int> todo-sort-index: ThemeSettings.todo-sort-field;
    property <int> doing-sort-index: ThemeSettings.doing-sort-field;
    property <int> done-sort-index: ThemeSettings.done-sort-field;

    // Ascending toggles — same pattern as combo indices for consistency.
    property <bool> todo-asc: ThemeSettings.todo-sort-ascending;
    property <bool> doing-asc: ThemeSettings.doing-sort-ascending;
    property <bool> done-asc: ThemeSettings.done-sort-ascending;

    DialogCard {
        width: 360px; height: 600px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;

        body := VerticalLayout {
            x: 0; y: 0; width: 100%; height: 100%;
            padding: 20px; spacing: 16px;

            DialogHeader { title: "设置"; close => { root.cancel(); } }

            // Theme mode
            VerticalLayout {
                spacing: 6px;
                Text { text: "主题"; color: Theme.text-secondary; }
                theme-combo := ComboBox {
                    model: ["跟随系统", "亮色", "暗色"];
                    current-index <=> root.theme-index;
                }
            }

            // Auto-archive
            VerticalLayout {
                spacing: 6px;

                HorizontalLayout {
                    spacing: 6px;
                    enable-check := CheckBox {
                        checked <=> ThemeSettings.auto-archive-enabled;
                    }
                    Text { text: "启用自动归档"; vertical-alignment: center; color: Theme.text-primary; }
                }

                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "归档天数（0 = 完成即归档）";
                        vertical-alignment: center;
                        color: ThemeSettings.auto-archive-enabled ? Theme.text-secondary
                            : Theme.text-secondary.with-alpha(0.4);
                    }
                    days-input := StyledTextInput {
                        text <=> root.days-text;
                        enabled: ThemeSettings.auto-archive-enabled;
                    }
                }
            }

            // Close behavior
            VerticalLayout {
                spacing: 6px;
                Text {
                    text: "关闭窗口行为";
                    color: Theme.text-secondary;
                }
                ComboBox {
                    model: ["每次询问", "彻底关闭", "最小化到托盘"];
                    current-index <=> root.close-behavior-index;
                }
            }

            // Column sort configuration
            VerticalLayout {
                spacing: 8px;

                Text {
                    text: "列排序";
                    font-weight: 600;
                    color: Theme.text-primary;
                }

                SortColumnRow { label: "📋 待办"; sort-field <=> root.todo-sort-index; ascending <=> root.todo-asc; }
                SortColumnRow { label: "🔄 进行中"; sort-field <=> root.doing-sort-index; ascending <=> root.doing-asc; }
                SortColumnRow { label: "✅ 已完成"; sort-field <=> root.done-sort-index; ascending <=> root.done-asc; }
            }

            DialogFooter {
                cancel => { root.cancel(); }
                confirm => {
                    // Write theme mode
                    ThemeSettings.theme-mode = root.theme-index == 0 ? "system"
                        : root.theme-index == 1 ? "light" : "dark";
                    ThemeSettings.auto-archive-days = root.days-text.to-float();

                    // Write close behavior
                    ThemeSettings.close-behavior = root.close-behavior-index == 0 ? ""
                        : root.close-behavior-index == 1 ? "quit" : "minimize_to_tray";

                    // Write sort field indices back to ThemeSettings
                    ThemeSettings.todo-sort-field = root.todo-sort-index;
                    ThemeSettings.doing-sort-field = root.doing-sort-index;
                    ThemeSettings.done-sort-field = root.done-sort-index;

                    // Write ascending toggles back to ThemeSettings
                    ThemeSettings.todo-sort-ascending = root.todo-asc;
                    ThemeSettings.doing-sort-ascending = root.doing-asc;
                    ThemeSettings.done-sort-ascending = root.done-asc;

                    root.confirm();
                }
            }
        }
    }
}
