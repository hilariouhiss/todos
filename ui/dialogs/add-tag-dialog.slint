import { Theme } from "../theme.slint";
import { StyledTextInput } from "../widgets/styled-text-input.slint";
import { ColorPresetsBar } from "../widgets/color-presets-bar.slint";
import { DialogCard, DialogHeader } from "../widgets/dialog-shell.slint";
import { DialogFooter } from "../widgets/dialog-footer.slint";

export component AddTagDialog inherits Rectangle {
    callback cancel();
    callback confirm(string, string);

    x: 0; y: 0; width: 100%; height: 100%;
    background: #00000044;
    TouchArea { }

    DialogCard {
        width: 320px; height: 260px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;

        body := VerticalLayout {
            x: 0; y: 0; width: 100%; height: 100%;
            padding: 20px; spacing: 12px;

            DialogHeader { title: "添加标签"; close => { root.cancel(); } }

            Text { text: "名称"; color: Theme.text-secondary; }
            name-input := StyledTextInput { }

            Text { text: "颜色"; color: Theme.text-secondary; }
            ColorPresetsBar { }

            DialogFooter {
                cancel => { root.cancel(); }
                confirm => { root.confirm(name-input.text, "#58a6ff"); }
            }
        }
    }
}
