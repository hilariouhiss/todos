import { Theme } from "theme.slint";
import { PriorityColors } from "common.slint";
import { DialogCard, DialogHeader } from "widgets/dialog-shell.slint";

// ---- Single archived-task row ----

component ArchivedRow inherits Rectangle {
    in property <string> title;
    in property <string> completed-at;
    in property <string> archived-at;
    in property <int> priority;
    in property <string> tags;

    height: 30px;
    background: transparent;

    HorizontalLayout {
        padding: 4px;
        spacing: 0;

        // Title column (flex)
        Text {
            text: root.title;
            color: Theme.text-primary;
            overflow: elide;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }

        // Completed column
        Text {
            text: root.completed-at;
            font-size: 12px;
            color: Theme.text-secondary;
            width: 120px;
            vertical-alignment: center;
        }

        // Archived column
        Text {
            text: root.archived-at;
            font-size: 12px;
            color: Theme.text-secondary;
            width: 120px;
            vertical-alignment: center;
        }

        // Priority
        Rectangle {
            width: 48px;
            Text {
                text: root.priority == 0 ? "P0" :
                      root.priority == 1 ? "P1" :
                      root.priority == 2 ? "P2" : "P3";
                font-size: 12px;
                color: root.priority == 0 ? PriorityColors.p0 :
                       root.priority == 1 ? PriorityColors.p1 :
                       root.priority == 2 ? PriorityColors.p2 : PriorityColors.p3;
                vertical-alignment: center;
            }
        }

        // Tags column
        Text {
            text: root.tags;
            font-size: 11px;
            color: Theme.text-secondary;
            width: 120px;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

// ---- Archived tasks overlay ----

export struct ArchivedTaskUi {
    title: string,
    completed-at: string,
    archived-at: string,
    priority: int,
    tags: string,
}

export component ArchivedTasksOverlay inherits Rectangle {
    callback close();

    x: 0; y: 0; width: 100%; height: 100%;
    background: #00000044;
    TouchArea { }

    in-out property <[ArchivedTaskUi]> tasks;

    DialogCard {
        width: 720px; height: 500px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;

        body := VerticalLayout {
            x: 0; y: 0; width: 100%; height: 100%;
            padding: 20px; spacing: 8px;

            DialogHeader { title: "已归档任务"; close => { root.close(); } }

            // Table header
            HorizontalLayout {
                padding: 4px;
                spacing: 0;

                Text {
                    text: "标题";
                    font-weight: 600;
                    font-size: 12px;
                    color: Theme.text-secondary;
                    horizontal-stretch: 1;
                }
                Text {
                    text: "完成日期";
                    font-weight: 600;
                    font-size: 12px;
                    color: Theme.text-secondary;
                    width: 120px;
                }
                Text {
                    text: "归档日期";
                    font-weight: 600;
                    font-size: 12px;
                    color: Theme.text-secondary;
                    width: 120px;
                }
                Text {
                    text: "优先级";
                    font-weight: 600;
                    font-size: 12px;
                    color: Theme.text-secondary;
                    width: 48px;
                }
                Text {
                    text: "标签";
                    font-weight: 600;
                    font-size: 12px;
                    color: Theme.text-secondary;
                    width: 120px;
                }
            }

            // Divider
            Rectangle { height: 1px; background: Theme.column-border; }

            // Task rows
            for task in root.tasks: ArchivedRow {
                title: task.title;
                completed-at: task.completed-at;
                archived-at: task.archived-at;
                priority: task.priority;
                tags: task.tags;
            }

            // Spacer: absorbs remaining space so rows stay at the top
            Rectangle { vertical-stretch: 1; }
        }
    }
}
